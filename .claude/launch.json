{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--host=0.0.0.0"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Backend (Express API)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/tsx/dist/cli.mjs", "server.ts"],
      "port": 3001
    }
  ]
}
